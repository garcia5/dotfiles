#!/bin/bash

[ -z "$JIRA_BASE_URL" ] && echo "define 'JIRA_BASE_URL' to use" && exit 1

if [[ "$1" =~ ^[A-Z0-9]+-[0-9]+$ ]]; then
    echo "[$1](${JIRA_BASE_URL}/browse/$1)" | pbcopy
    exit 0
fi

if [[ "$1" =~ ^[0-9]+$ ]] && [ -n "$DEFAULT_JIRA_PROJECT" ]; then
    ticket="${DEFAULT_JIRA_PROJECT}-$1"
    echo "[$ticket](${JIRA_BASE_URL}/browse/$ticket)" | pbcopy
    exit 0
fi

echo "Invalid jira ticket $1"
exit 1
